# =============================================================================
# RADCloud — example environment variables
# =============================================================================
# Copy the BACKEND block into `backend/.env` (or export in your shell before
# running uvicorn). Copy the FRONTEND block into `frontend/.env.local` for Vite.
# Never commit real secrets; `.env` is gitignored.
# =============================================================================

# --- BACKEND (FastAPI / agents / RAG) ----------------------------------------
# AWS credentials for Bedrock (Claude + Titan embeddings). Alternatively use
# ~/.aws/credentials, IAM instance role, or AWS SSO (`aws sso login`).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: temporary credentials / assumed role
# AWS_SESSION_TOKEN=

AWS_DEFAULT_REGION=us-east-1

# Claude on Bedrock (console → model access → copy model ID)
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# LLM: auto (Bedrock then OpenAI) | bedrock | openai
# LLM_PROVIDER=auto
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# JWT signing secret for /auth (change in production)
# JWT_SECRET=radcloud-dev-secret-change-in-production

# SQLite database file. Local default: backend/radcloud.db. On Railway, if unset,
# the app uses /tmp/radcloud.db (writable). Do NOT set RADCLOUD_DB_PATH to an empty
# value in Railway — that breaks auth (500 on signup). Omit the variable or set a full path.
# RADCLOUD_DB_PATH=

# Return cached pipeline JSON; skip live agents + Bedrock
# DEMO_MODE=true

# --- Railway (dashboard only; do not paste real secrets into repo files) -----
# https://railway.app → Project → **radcloud** service → **Variables** → New Variable
#
#   JWT_SECRET                      (long random string)
#   AWS_ACCESS_KEY_ID               (optional — Bedrock / RAG; rotate if ever leaked)
#   AWS_SECRET_ACCESS_KEY
#   AWS_DEFAULT_REGION=us-east-1
#   DEMO_MODE=true                  (optional — cached pipeline without Bedrock)
#
# Fixed demo login without using Signup UI (values only in Railway, never in git):
#   RADCLOUD_BOOTSTRAP_EMAIL=you@example.com
#   RADCLOUD_BOOTSTRAP_PASSWORD=your-password
#   RADCLOUD_BOOTSTRAP_NAME=Your Name          (optional)
#   RADCLOUD_BOOTSTRAP_COMPANY=Your Co           (optional)
#
# Do not set VITE_* on this service for the root Dockerfile deploy (same-origin API).

# --- FRONTEND (Vite) ---------------------------------------------------------
# Dev: leave empty to use Vite proxy to localhost:8000
# Production / custom API: VITE_API_URL=https://api.example.com
# VITE_API_URL=

# Bundle static demo data only (no backend analyze call)
# VITE_DEMO_MODE=true

# GitHub Pages / subpath deploy: VITE_BASE=/YourRepoName/
# VITE_BASE=/
