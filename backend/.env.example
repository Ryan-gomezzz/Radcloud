# AWS credentials for Amazon Bedrock (or use ~/.aws/credentials / IAM role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Optional: override Claude on Bedrock (see AWS Bedrock console for exact model ID)
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# Demo: skip agents + Bedrock and return cached JSON
# DEMO_MODE=true
