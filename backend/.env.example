# AWS — Bedrock (Claude chat + Titan embeddings for RAG)
# Use ~/.aws/credentials, IAM role, or SSO if you prefer not to set these.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Optional: override Bedrock chat model ID
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6

# JWT secret for signup/login (production: use a long random string)
# JWT_SECRET=radcloud-dev-secret-change-in-production

# SQLite path (default: radcloud.db next to this package). On Railway, leave unset
# to use /tmp/radcloud.db, or set a path on a mounted volume. Never set empty.
# RADCLOUD_DB_PATH=

# Skip LLM pipeline; serve cached demo JSON from data/cached_response.json
# DEMO_MODE=true

# Railway: auto-create or reset password for one user (never commit real values)
# RADCLOUD_BOOTSTRAP_EMAIL=
# RADCLOUD_BOOTSTRAP_PASSWORD=
# RADCLOUD_BOOTSTRAP_NAME=
# RADCLOUD_BOOTSTRAP_COMPANY=
